{
  "manifest_version": 3,
  "name": "Dundam Sort Bar",
  "version": "0.1.0",
  "description": "Adds a sort control bar to Dundam search result pages.",
  "icons": {
    "16": "icons/dundam-16.png",
    "32": "icons/dundam-32.png",
    "64": "icons/dundam-64.png",
    "128": "icons/dundam-128.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Dundam Sort Bar",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/dundam-16.png",
      "32": "icons/dundam-32.png",
      "64": "icons/dundam-64.png",
      "128": "icons/dundam-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://dundam.xyz/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
